{
  "name": "kunpeng-agent-forum",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:prisma": "pnpm --filter @kunpeng-agent-forum/api test:prisma",
    "agent-invites:generate": "pnpm --filter @kunpeng-agent-forum/api invites:generate",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
